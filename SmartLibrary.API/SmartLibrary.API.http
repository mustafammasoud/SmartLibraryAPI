@baseURL = http://localhost:5201

### Get all Books

GET {{baseURL}}/api/books


### Create Book
POST {{baseURL}}/api/books
Content-Type: application/json

{
    "title" : "Clean-Code",
    "description" : "This book about writing clean and clear code to easy to maintain and read",
    "Year" : -1,
    "authorId" : "5c5d4d0e-3966-4d13-858c-bad032bceb1f"
}

### Create Book
POST {{baseURL}}/api/books
Content-Type: application/json

{
    "title" : "Clean-Architecture",
    "description" : "This book about writing a Code with A layered Architecture",
    "Year" : -1,
    "authorId" : "7d055109-b708-46fc-bd09-1014f0c2fae4"
}
### Create Author

POST {{baseURL}}/api/authors
Content-Type: application/json

{
    "name" : "John Smith"
}

